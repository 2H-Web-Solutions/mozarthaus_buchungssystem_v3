# Firebase Configuration
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-auth-domain"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-storage-bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# n8n Automation Webhooks
VITE_N8N_WEBHOOK_URL="https://n8n.my-agency.com/webhook/mozarthaus-booking-sync"
VITE_N8N_REGIONDO_SYNC_WEBHOOK_URL="https://n8n.my-agency.com/webhook/regiondo-fetch-events"

# Regiondo REST API (Vite dev/preview proxy only — keys are scrubbed from the client bundle in vite.config.ts; do not use import.meta.env.* for these in src/)
VITE_REGIONDO_PUBLIC_KEY="your-regiondo-public-api-key"
VITE_REGIONDO_PRIVATE_KEY="your-regiondo-private-api-key"
# API host (no trailing slash). Sandbox → https://sandbox-api.regiondo.com — live → https://api.regiondo.com
# VITE_REGIONDO_API_HOST="https://sandbox-api.regiondo.com"
# Legacy aliases (still supported by vite/plugins/regiondoProductsApi.ts):
# REGIONDO_PUBLIC_KEY=
# REGIONDO_PRIVATE_KEY=
# REGIONDO_API_HOST=

# Optional: full URL to a deployed proxy that lists Regiondo products (required for static production builds where /api is not available).
# The same base URL is reused for product availabilities (`…/products/availabilities/{variationId}`).
# VITE_REGIONDO_PRODUCTS_API_URL="https://your-backend.example.com/regiondo/products"
