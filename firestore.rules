rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Beschränke alles auf den Projekt-Scope
    match /apps/mozarthaus_new_buchungssystem_mozarthaus_v1/{document=**} {
      // Für den MVP/Build-Status: Erlaube Lese-/Schreibzugriff (später durch Auth ersetzen)
      allow read, write: if true; 
    }
    // Verbiete Zugriff auf alles außerhalb des Scopes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
