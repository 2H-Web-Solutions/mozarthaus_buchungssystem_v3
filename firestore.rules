rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Geschützter App Scope (Production Mode)
    match /apps/mozarthaus_new_buchungssystem_mozarthaus_v1/{document=**} {
      // Erlaube Zugriff NUR, wenn der User eingeloggt ist
      allow read, write: if request.auth != null;
    }

    // 2. Public Reports (falls extern benötigt, z.B. für n8n ohne Auth-Token)
    match /apps/mozarthaus_new_buchungssystem_mozarthaus_v1/public_reports/{reportId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. GLOBAL ACCESS BLOCK
    match /{document=**} {
      allow read, write: if false;
    }
    
  }
}
